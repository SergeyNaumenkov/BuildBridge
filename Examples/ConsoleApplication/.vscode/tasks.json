{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MSBuild x64 Debug",
            "type": "shell",
            "command": "C:/Program Files/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe",
            "args": [
                "${workspaceFolder}/ConsoleApplication.slnx",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "MSBuild x64 Release",
            "type": "shell",
            "command": "C:/Program Files/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe",
            "args": [
                "${workspaceFolder}/ConsoleApplication.slnx",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": "$msCompile"
        }
    ]
}