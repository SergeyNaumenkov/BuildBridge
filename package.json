{
  "name": "buildbridge",
  "displayName": "BuildBridge",
  "description": "Visual Studio Properties Pages for C++ MSBuild projects in VS Code. Create, Edit, Build and Debug .vcxproj / .slnx projects without opening Visual Studio",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "C++",
    "c++",
    "cpp",
    "msbuild",
    "vcxproj",
    "slnx",
    "visual studio",
    "msvc",
    "cmake alternative"
  ],
  "activationEvents": [
    "workspaceContains:**/*.slnx",
    "workspaceContains:**/*vcxproj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "buildbridge-container",
          "title": "Build Bridge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "buildbridge.getBuildTask",
          "when": "false"
        },
        {
          "command": "buildbridge.getExePath",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "buildbridge.newFile",
          "when": "view == buildbridge-projects && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "buildbridge.project.properties",
          "when": "view == buildbridge-projects && viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "buildbridge.project.file.delete",
          "when": "view == buildbridge-projects && viewItem == cpp || viewItem == header",
          "group": "inline@3"
        }
      ]
    },
    "views": {
      "buildbridge-container": [
        {
          "icon": "media/icon.svg",
          "id": "buildbridge-projects",
          "name": "Projects",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "buildbridge.cpp.CreateConsoleApplication",
        "title": "Create cpp console application",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.cpp.CreateProjectWeb",
        "title": "Create Project via WebView",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.cpp.OpenProject",
        "title": "Open project from folder",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.getExePath",
        "title": "Get path to exe",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.getBuildTask",
        "title": "Get build task",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.selectConfig",
        "title": "Select configuration for project",
        "category": "BuildBridge"
      },
      {
        "command": "buildbridge.newFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "buildbridge.project.properties",
        "title": "Properties",
        "icon": "$(symbol-property)"
      },
      {
        "command": "buildbridge.project.file.delete",
        "title": "Delete",
        "icon": "$(trash)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@types/xml2js": "^0.4.14",
    "@types/xmldom": "^0.1.34",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.2",
    "xmldom": "^0.6.0"
  }
}