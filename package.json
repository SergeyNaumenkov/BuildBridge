{
  "name": "buildbridge",
  "displayName": "BuildBridge",
  "description": "Visual Studio Properties Pages for C++ MSBuild projects in VS Code. Create, Edit, Build and Debug .vcxproj / .slnx projects without opening Visual Studio",
  "version": "0.1.3",
  "publisher": "sergeynaumenkovdev",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SergeyNaumenkov/BuildBridge"
  },
  "icon": "media/icon.png",
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "C++",
    "c++",
    "cpp",
    "msbuild",
    "vcxproj",
    "slnx",
    "visual studio",
    "msvc",
    "cmake alternative"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "buildbridge-solution-container",
          "title": "Build Bridge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "buildbridge-solution-container": [
        {
          "id": "buildbridge-solution-container-id",
          "name": "Project Explorer",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@types/xml2js": "^0.4.14",
    "@types/xmldom": "^0.1.34",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.2",
    "xmldom": "^0.6.0"
  }
}